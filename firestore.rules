rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funções auxiliares
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isNotLocked() {
      return resource.data.account_status != 'RISK_LOCKED';
    }

    // Usuários
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && isNotLocked()) || isAdmin();
      allow delete: if isAdmin();
    }

    // Semanas
    match /weeks/{weekId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.owner_id == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Trocas - apenas o backend (Admin SDK) pode modificar
    match /exchanges/{exchangeId} {
      allow read: if isAuthenticated() && (
        resource.data.requester_id == request.auth.uid ||
        resource.data.owner_id == request.auth.uid
      );
      allow write: if isAdmin();
    }

    // Escrows - apenas o backend
    match /escrows/{escrowId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Lotes de créditos - apenas o backend
    match /credit_batches/{batchId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow write: if isAdmin();
    }

    // Estatísticas da plataforma
    match /platform/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
