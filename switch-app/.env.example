GEMINI_API_KEY="MY_GEMINI_API_KEY"
ASAAS_API_KEY="MY_ASAAS_API_KEY"
# sandbox | production (não use a API key para inferir ambiente)
ASAAS_ENVIRONMENT="sandbox"
# Token do webhook no painel Asaas (cabeçalho asaas-access-token). Obrigatório em produção.
ASAAS_WEBHOOK_TOKEN="MY_WEBHOOK_TOKEN"
# Origem do front (produção: https://seu-dominio.com). Várias origens: separar por vírgula.
ALLOWED_ORIGIN="http://localhost:3000"
PORT="3000"
